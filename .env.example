# ============================================
# GovScheme AI Monitor - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# MongoDB Atlas (required)
MONGO_URI= mongodb+srv://med_user:med_pass@cluster0.stgyl.mongodb.net/gov_ai_project?retryWrites=true&w=majority&appName=Cluster0

# Google Gemini AI (required)
# Get free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDLX67OZrn6VN200hOry21TvI5T88Tar4U

# WordPress (optional - for publishing)
WP_URL=https://your-wordpress-site.com/wp-json/wp/v2
WP_USER=admin
WP_PASSWORD=your-application-password

# Gmail SMTP (optional - for email notifications)
# Must use App Password, not regular password
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_PASSWORD=your-app-password-here
NOTIFY_EMAIL=notify@gmail.com

# Scheduler interval in minutes (default: 30)
SCHEDULER_INTERVAL=30

# Debug mode
DEBUG=True
